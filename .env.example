# ── Clodia Agency — configurazione istanza ──────────────────────────────────
# Copia in .env (lo fa setup.sh) e compila i valori. NON committare .env.

# Datadir: dove vivono TUTTI i dati dell'istanza (secrets, topics, db, pki).
# Percorso assoluto consigliato. Default: ./clodia-data
CLODIA_DATA=./clodia-data

# Modello: chiave API Anthropic (provider minimo per far girare gli agenti).
# In alternativa si collega un provider OAuth dalla sezione Tools della webui.
ANTHROPIC_API_KEY=

# Mailbox reale dell'agency (per i canali di contatto via subaddressing).
# Es. la-tua-agency@gmail.com — lascia vuoto se non usi i canali email.
CLODIA_BASE_EMAIL=

# Sorgente del codice agent-server (clonato a runtime). Lascia i default.
GIT_REPO=r-clodia/clodia-logic
GIT_BRANCH=main

# Porte host (cambiale se già occupate)
AGENT_SERVER_PORT=7842
TOOLS_PORT=7849
WEBUI_PORT=7843
PWA_PORT=5173

# Integrazione opzionale: bot Telegram (si può anche configurare da UI)
TELEGRAM_BOT_TOKEN=
